{
  "name": "c-cpp-codelens",
  "displayName": "c_cpp_codelens",
  "description": "",
  "version": "1.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:cpp",
    "onLanguage:c"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "c-cpp-codelens.runCode",
        "title": "Run code"
      },
      {
        "command": "c-cpp-codelens.compileCode",
        "title": "Compile code"
      },
      {
        "command": "c-cpp-codelens.compileAndRunCode",
        "title": "Compile and Run code"
      },
      {
        "command": "c-cpp-codelens.debugCode",
        "title": "Debug code"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UOM-EEE-EEEN11202/c_cpp_codelens"
  },
  "license": "MIT",
  "publisher": "uom-eee-eeen11202"
}
